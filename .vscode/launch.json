{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ChivaTask",
      "type": "debugpy",
      "request": "launch",
      "module": "uph_pendientes",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      },
      "justMyCode": true
    },
    {
      "name": "ChivaTask (UI offscreen smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "uph_pendientes",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src",
        "QT_QPA_PLATFORM": "offscreen"
      },
      "justMyCode": true
    }
  ]
}
